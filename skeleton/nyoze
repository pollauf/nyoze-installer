#!/usr/bin/env php
<?php

require __DIR__ . '/vendor/autoload.php';

use App\Context;
use Nyoze\CLI\Console;
use Nyoze\Core\Kernel;
use Nyoze\Data\PdoRepository;
use Nyoze\Support\Config;

$config = Config::fromEnv(__DIR__ . '/.env');

// ─── Command routing ────────────────────────────────────────────────
$command = $argv[1] ?? 'help';

// Serve command (handled before app bootstrap — no DB needed)
if ($command === 'serve') {
    $port = '8000';
    foreach (array_slice($argv, 2) as $arg) {
        if (str_starts_with($arg, '--port=')) {
            $port = substr($arg, 7);
        }
    }

    $host = 'localhost';
    echo "\033[32mNyoze development server started:\033[0m http://{$host}:{$port}" . PHP_EOL;
    echo "Press Ctrl+C to stop." . PHP_EOL;

    $exitCode = 0;
    passthru("php -S {$host}:{$port} index.php", $exitCode);
    exit($exitCode);
}

// Help command
if ($command === 'help' || $command === '--help' || $command === '-h') {
    echo "Nyoze CLI" . PHP_EOL;
    echo PHP_EOL;
    echo "Usage:" . PHP_EOL;
    echo "  nyoze <command>" . PHP_EOL;
    echo PHP_EOL;
    echo "Available commands:" . PHP_EOL;
    echo "  serve              Start the development server" . PHP_EOL;
    echo "  migrate            Run pending migrations" . PHP_EOL;
    echo "  make:migration     Generate migration files from entities" . PHP_EOL;
    echo "  migrate:rollback   Rollback the last migration" . PHP_EOL;
    echo "  entities           List registered entities" . PHP_EOL;
    echo "  schema:dump        Dump schema to JSON" . PHP_EOL;
    echo "  help               Show this help message" . PHP_EOL;
    echo PHP_EOL;
    exit(0);
}

// Commands that need app bootstrap
$dsn = $config->get('DB_DSN', 'sqlite:database.sqlite');
$pdo = new PDO($dsn, $config->get('DB_USER'), $config->get('DB_PASS'));
$pdo->setAttribute(PDO::ATTR_ERRMODE, PDO::ERRMODE_EXCEPTION);

$kernel = Kernel::load(function (\Nyoze\Core\App $app) use ($pdo) {
    $app->useRepository(new PdoRepository($pdo));
    (new Context())->register($app);
});

$console = new Console($kernel->app());
exit($console->run($argv));
